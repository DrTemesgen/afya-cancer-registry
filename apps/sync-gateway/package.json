{
  "name": "@afya-acr/sync-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Sync & aggregate roll-up gateway for the Afya Cancer Registry. Federates de-identified aggregates up the hierarchy and exposes FHIR/DHIS2/IARC endpoints.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
